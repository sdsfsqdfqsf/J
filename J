--  MAIN HEARTBEAT LOOP
-- ═══════════════════════════════════════════════════════════════
local espRefreshTick = 0

RunService.Heartbeat:Connect(function()
    safe(function()
        if not refreshChar() then return end

        -- Live status update
        local data = getQD()
        statusPara:SetContent(
            "Phase: " .. farmPhase
            .. "  |  Kills: " .. farmKills .. "/8"
            .. "  |  Lv: "    .. getLevel()
            .. "  |  Target: " .. data[3]
            .. "  |  " .. seaName
        )

        local Ss = _G.Settings

        -- Player attributes (real BF names)
        doPlayerAttrs()

        -- Combat
        if Ss.Farm["Kill Aura"]         then doKillAura()  end
        if Ss.Stats["Auto Haki"]         then doAutoHaki()  end
        if Ss.Stats["Auto Observation"]  then doAutoObs()   end
        if Ss.Stats["Auto Stats"]        then doAutoStats() end

        -- Boss
        if Ss.Farm["Auto Boss"] then
            attackBoss(Ss.Farm["Selected Boss"])
        end

        -- Sea Beast (workspace.Enemies method)
        if Ss.Farm["Auto Sea Beast"] then
            safe(function()
                local folder = workspace:FindFirstChild("Enemies")
                if not folder then return end
                for _, v in pairs(folder:GetChildren()) do
                    if v.Name:find("Sea Beast")  or
                       v.Name:find("Terrorshark") or
                       v.Name:find("Leviathan") then
                        local h = v:FindFirstChild("Humanoid")
                        local r = v:FindFirstChild("HumanoidRootPart")
                        if h and h.Health > 0 and r then
                            if (r.Position-HRP.Position).Magnitude > 15 then
                                tpTo(r.CFrame * CFrame.new(0,0,-15), true)
                            end
                            doAttack()
                        end
                    end
                end
            end)
        end

        -- Elite Hunter
        if Ss.Farm["Auto Elite Hunter"] then
            safe(function()
                local folder = workspace:FindFirstChild("Enemies")
                if not folder then return end
                for _, v in pairs(folder:GetChildren()) do
                    if v.Name:find("Elite") then
                        local h = v:FindFirstChild("Humanoid")
                        local r = v:FindFirstChild("HumanoidRootPart")
                        if h and h.Health > 0 and r then
                            tpTo(r.CFrame * CFrame.new(0,0,-8), true)
                            doAttack()
                        end
                    end
                end
            end)
        end

        -- Collect Chest
        if Ss.Farm["Auto Collect Chest"] then
            safe(function()
                for _, m in pairs(workspace:GetDescendants()) do
                    if m:IsA("Model") and
                    (m.Name:lower():find("chest") or m.Name:lower():find("treasure")) then
                        local part = m.PrimaryPart or m:FindFirstChildOfClass("Part")
                        if part and HRP and
                        (part.Position-HRP.Position).Magnitude < 600 then
                            tpTo(part.CFrame, true)
                            task.wait(0.3)
                        end
                    end
                end
            end)
        end

        -- Bounty
        if Ss.Farm["Auto Bounty"] then
            safe(function()
                local best, bestB, bestR = nil, 0, nil
                for _, p in pairs(Players:GetPlayers()) do
                    if p==LP or not p.Character then continue end
                    local ls = p:FindFirstChild("leaderstats")
                    if not ls then continue end
                    local bv = ls:FindFirstChild("Bounty") or ls:FindFirstChild("Beli")
                    local val = bv and bv.Value or 0
                    local r = p.Character:FindFirstChild("HumanoidRootPart")
                    if r and val > bestB then bestB=val; best=p; bestR=r end
                end
                if bestR then tpTo(bestR.CFrame, true); doAttack() end
            end)
        end

        -- Fruit
        if Ss.Fruit["Fruit Sniper"]    then doFruitSniper() end

        -- No Clip
        if Ss.Player["No Clip"] then doNoClip() end

        -- One-time misc
        if Ss.Misc["Remove Fog"] then doRemoveFog() end
        if Ss.Misc["FPS Boost"]  then doFPSBoost()  end

        -- ESP refresh every 3 seconds
        if tick() - espRefreshTick > 3 then
            espRefreshTick = tick()
            if Ss.ESP["Fruit ESP"]  then doFruitESP()  end
            if Ss.ESP["Player ESP"] then doPlayerESP() end
            if Ss.ESP["Chest ESP"]  then doChestESP()  end
            if Ss.ESP["Mob ESP"]    then doMobESP()     end
        end
    end)
end)


local Char, Hum, HRP

local function refreshChar()
    Char = LP.Character
    if not Char then return false end
    Hum  = Char:FindFirstChildOfClass("Humanoid")
    HRP  = Char:FindFirstChild("HumanoidRootPart")
    return Hum ~= nil and HRP ~= nil
end
refreshChar()

-- ═══════════════════════════════════════════════════════════════
--  COMMF_ REMOTE
-- ═══════════════════════════════════════════════════════════════
local CommF_
local function getCommF()
    if CommF_ and CommF_.Parent then return CommF_ end
    local rem = RS:FindFirstChild("Remotes")
    if not rem then return nil end
    CommF_ = rem:FindFirstChild("CommF_")
    return CommF_
end

local function invoke(...)
    local args, result = {...}, nil
    safe(function()
        local c = getCommF()
        if not c then warn("[BFHub] CommF_ not found"); return end
        result = c:InvokeServer(table.unpack(args))
    end)
    return result
end

-- ═══════════════════════════════════════════════════════════════
--  GET LEVEL  (from SkyX — uses player.Data.Level.Value)
-- ═══════════════════════════════════════════════════════════════
local function getLevel()
    local lv = 1
    safe(function()
        -- Real BF path (SkyX confirmed)
        local data = LP:FindFirstChild("Data")
        if data then
            local lvNode = data:FindFirstChild("Level")
            if lvNode then lv = lvNode.Value; return end
        end
        -- Fallback: leaderstats
        local s = LP:FindFirstChild("leaderstats")
        if not s then return end
        for _, v in pairs(s:GetChildren()) do
            if v.Name:lower():find("lv") or v.Name:lower():find("level") then
                lv = v.Value
            end
        end
    end)
    return lv
end


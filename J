--  FIND ENEMY  (SkyX method — workspace.Enemies, NOT GetDescendants)
-- ═══════════════════════════════════════════════════════════════
local function findEnemy(name)
    local best, bestDist = nil, math.huge
    if not HRP then return nil, math.huge end
    safe(function()
        local folder = workspace:FindFirstChild("Enemies")
        if not folder then return end
        for _, v in pairs(folder:GetChildren()) do
            if v.Name == name or v.Name:find(name, 1, true) then
                local h = v:FindFirstChild("Humanoid")
                local r = v:FindFirstChild("HumanoidRootPart")
                if h and h.Health > 0 and r then
                    local d = (r.Position - HRP.Position).Magnitude
                    if d < bestDist then bestDist=d; best=r end
                end
            end
        end
    end)
    return best, bestDist
end

-- ═══════════════════════════════════════════════════════════════
--  MOB MAGNET  (SkyX real method)
--  sethiddenproperty + HRP Size 50 + ChangeState(14) + no collision
-- ═══════════════════════════════════════════════════════════════
local magnetActive = false
local magnetCFrame = CFrame.new(0,0,0)

local function startMagnet(monName)
    magnetActive = true
    task.spawn(function()
        while magnetActive do
            task.wait()
            safe(function()
                if not HRP then return end
                magnetCFrame = HRP.CFrame
                local folder = workspace:FindFirstChild("Enemies")
                if not folder then return end
                local range = _G.Settings.Farm["Bring Range"]
                for _, v in pairs(folder:GetChildren()) do
                    if v.Name == monName or v.Name:find(monName, 1, true) then
                        local h = v:FindFirstChild("Humanoid")
                        local r = v:FindFirstChild("HumanoidRootPart")
                        local head = v:FindFirstChild("Head")
                        if h and h.Health > 0 and r then
                            if (r.Position - HRP.Position).Magnitude <= range then
                                r.Size      = Vector3.new(50,50,50)
                                r.CFrame    = magnetCFrame
                                h:ChangeState(14)
                                r.CanCollide = false
                                if head then head.CanCollide = false end
                                if h:FindFirstChild("Animator") then
                                    h.Animator:Destroy()
                                end
                                pcall(sethiddenproperty,
                                    LP, "SimulationRadius", math.huge)
                            end
                        end
                    end
                end
            end)
        end
    end)
end

local function stopMagnet() magnetActive = false end


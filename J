-- ═══════════════════════════════════════════════════════════════
--  HELPER — GET CURRENT QUEST DATA
-- ═══════════════════════════════════════════════════════════════
local function getQD()
    local lv = getLevel()
    for _, d in ipairs(QuestData) do
        if lv >= d[1] and lv <= d[2] then return d end
    end
    return QuestData[1] or QuestData[#QuestData]
end

-- ═══════════════════════════════════════════════════════════════
--  TELEPORT  (tween close, instant far)
-- ═══════════════════════════════════════════════════════════════
local function tpTo(cf, instant)
    if not HRP then return end
    safe(function()
        if typeof(cf) == "Instance" then cf = cf.CFrame end
        if instant or (cf.Position - HRP.Position).Magnitude > 100 then
            HRP.CFrame = cf
            task.wait(0.15)
        else
            local tw = TweenService:Create(
                HRP, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame=cf}
            )
            tw:Play(); tw.Completed:Wait()
        end
    end)
end


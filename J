-- ═══════════════════════════════════════════════════════════════
--  AUTO FARM LOOP  (3-phase: GET_QUEST → KILL → TURN_IN)
--  Uses real CFrames from SkyX + requestEntrance for gated islands
-- ═══════════════════════════════════════════════════════════════
local farmPhase   = "IDLE"
local farmKills   = 0
local lastEnemyHP = 0
local farmConn    = nil
local farmStatus  = "Idle"

local function stopFarm()
    _G.Settings.Farm["Auto Farm"] = false
    if farmConn then farmConn:Disconnect(); farmConn=nil end
    stopMagnet()
    farmPhase="IDLE"; farmKills=0; farmStatus="Idle"
end

local function startFarm()
    stopFarm()
    _G.Settings.Farm["Auto Farm"] = true
    farmPhase = "GET_QUEST"; farmKills = 0

    farmConn = RunService.Heartbeat:Connect(function()
        if not _G.Settings.Farm["Auto Farm"] then stopFarm(); return end
        if not refreshChar() then
            task.wait(2); farmPhase="GET_QUEST"; return
        end

        local data = getQD()
        -- data indices:
        -- [1]=minLv [2]=maxLv [3]=monName [4]=questID [5]=questNum
        -- [6]=questNPCCFrame [7]=monSpawnCFrame
        -- [8]=needsEntrance [9]=entranceVec3

        -- ── PHASE 1: ACCEPT QUEST ──────────────────────────
        if farmPhase == "GET_QUEST" then
            farmStatus = "Getting quest: " .. data[4]
            if _G.Settings.Farm["Auto Quest"] then
                safe(function()
                    -- Handle gated islands (Fishman City, Ship, etc.)
                    if data[8] then
                        local monPos = data[7].Position
                        if (monPos - HRP.Position).Magnitude > 3000 then
                            requestEntrance(data[9])
                            task.wait(1.5)
                        end
                    end
                    -- TP to quest NPC (exact SkyX CFrame)
                    tpTo(data[6], true)
                    task.wait(0.8)
                    -- Real CommF_ quest invoke
                    invoke("StartQuest", data[4], data[5])
                    task.wait(0.4)
                end)
            end
            if _G.Settings.Farm["Bring Mob"] then
                startMagnet(data[3])
            end
            farmKills=0; lastEnemyHP=0; farmPhase="KILL"

        -- ── PHASE 2: KILL ──────────────────────────────────
        elseif farmPhase == "KILL" then
            farmStatus = "Farming " .. data[3] .. " (" .. farmKills .. "/8)"
            safe(function()
                -- TP near mob spawn (SkyX real coords)
                local spawnDist = (data[7].Position - HRP.Position).Magnitude
                if spawnDist > 50 then tpTo(data[7], true) end

                -- Find alive enemy in workspace.Enemies
                local enemy, eDist = findEnemy(data[3])
                if not enemy then return end
                local hum = enemy.Parent:FindFirstChildOfClass("Humanoid")
                if not hum then return end

                -- Kill detection
                if hum.Health <= 0 and lastEnemyHP > 0 then
                    farmKills += 1; lastEnemyHP=0; task.wait(0.3); return
                end
                lastEnemyHP = hum.Health

                if eDist > 10 then tpTo(enemy.CFrame * CFrame.new(0,0,-8), true) end
                doAttack()

                local Ss = _G.Settings
                if Ss.Stats["Auto Mastery"]     then doMastery()   end
                if Ss.Stats["Auto Haki"]         then doAutoHaki()  end
                if Ss.Stats["Auto Observation"]  then doAutoObs()   end
                if Ss.Stats["Auto Stats"]        then doAutoStats() end
                if Ss.Farm["Kill Aura"]          then doKillAura()  end
            end)

            if farmKills >= 8 then farmPhase = "TURN_IN" end

        -- ── PHASE 3: TURN IN ───────────────────────────────
        elseif farmPhase == "TURN_IN" then
            farmStatus = "Turning in quest..."
            if _G.Settings.Farm["Auto Quest"] then
                safe(function()
                    tpTo(data[6], true)
                    task.wait(0.7)
                    invoke("EndQuest")
                    task.wait(0.4)
                end)
            end
            stopMagnet()
            farmKills=0; lastEnemyHP=0; farmPhase="GET_QUEST"
        end
    end)
end


local ESPBBs = {fruit={}, player={}, chest={}, mob={}}

local function clearESP(t)
    for _, v in pairs(t) do
        safe(function() if v and v.Parent then v:Destroy() end end)
    end
    table.clear(t)
end

local function makeESP(parent, text, color)
    if not parent then return end
    safe(function()
        local old = parent:FindFirstChild("__ESP")
        if old then old:Destroy() end
        local bb = Instance.new("BillboardGui")
        bb.Name = "__ESP"
        bb.Size = UDim2.new(0,130,0,32)
        bb.StudsOffset = Vector3.new(0,5,0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = 1000
        bb.Parent = parent
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = color
        lbl.TextStrokeTransparency = 0
        lbl.TextStrokeColor3 = Color3.new(0,0,0)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 11
        lbl.Text = text
        lbl.Parent = bb
    end)
end

local function doFruitESP()
    clearESP(ESPBBs.fruit)
    safe(function()
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Model") and v.Name:find("[Ff]ruit") then
                local part = v:FindFirstChild("Handle")
                          or v.PrimaryPart or v:FindFirstChildOfClass("Part")
                if part then
                    makeESP(part, "🍎 "..v.Name, Color3.fromRGB(255,220,0))
                    table.insert(ESPBBs.fruit, part:FindFirstChild("__ESP"))
                end
            end
        end
    end)
end

local function doPlayerESP()
    clearESP(ESPBBs.player)
    safe(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p==LP or not p.Character then continue end
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local hum  = p.Character:FindFirstChildOfClass("Humanoid")
            if not (root and hum) then continue end
            local hp  = math.floor(hum.Health)
            local mhp = math.floor(hum.MaxHealth)
            local pct = mhp > 0 and (hp/mhp) or 0
            makeESP(root,
                "["..p.Name.."]\nHP: "..hp.."/"..mhp,
                Color3.fromRGB(
                    math.floor(255*(1-pct)),
                    math.floor(255*pct),
                    0
                )
            )
            table.insert(ESPBBs.player, root:FindFirstChild("__ESP"))
        end
    end)
end

local function doChestESP()
    clearESP(ESPBBs.chest)
